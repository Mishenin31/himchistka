<UserControl x:Class="Himchistka.UI.Views.AcceptOrderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Прием заказа" FontSize="24" FontWeight="Bold" />
        <DataGrid Grid.Row="1" AutoGenerateColumns="True" Margin="0,10,0,10" />
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <TextBlock Text="Итого: " VerticalAlignment="Center" FontWeight="Bold"/>
            <TextBlock Text="{Binding Total}" VerticalAlignment="Center" Margin="4,0"/>
            <Button Content="Печать квитанции" Margin="10,0,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>
