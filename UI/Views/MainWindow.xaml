<Window x:Class="Himchistka.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Химчистка" Height="720" Width="1200" MinWidth="900" MinHeight="600">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Background="#1F2A44" Grid.Column="0">
            <StackPanel Margin="16">
                <TextBlock Text="🧺 Химчистка" Foreground="White" FontSize="20" FontWeight="Bold" Margin="0 0 0 20"/>
                <Button Content="Заказы" Command="{Binding NavigateOrdersCommand}" />
                <Button Content="Клиенты" Command="{Binding NavigateClientsCommand}" />
                <Button Content="Услуги" Command="{Binding NavigateServicesCommand}" />
                <Button Content="Отчеты" Command="{Binding NavigateReportsCommand}" />
                <Button Content="Администрирование" Command="{Binding NavigateAdminCommand}" />
            </StackPanel>
        </Border>

        <ContentControl Grid.Column="1" Content="{Binding CurrentPage}" Margin="16" />
    </Grid>
</Window>
